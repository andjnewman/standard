
# Volunteering vocabulary

## Namespaces
### Ontology Base URI
prefix :                <https://ns.volunteeringdata.io/>

### Core W3C ontologies (OWL 2 reserved vocabulary)
prefix rdf:             <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
prefix rdfs:            <http://www.w3.org/2000/01/rdf-schema#>
prefix owl:             <http://www.w3.org/2002/07/owl#>
prefix xsd:             <http://www.w3.org/2001/XMLSchema#>

### Other namespaces used
prefix dc:              <http://purl.org/dc/terms/>
prefix skos:            <http://www.w3.org/2004/02/skos/core#>
prefix time:            <http://www.w3.org/2006/time#>
prefix vcard:           <http://www.w3.org/2006/vcard/ns#>
prefix vann:            <http://purl.org/vocab/vann/>


# Activity Class
:Activity
    a owl:Class ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    rdfs:label "Activity"@en ;
    rdfs:comment "Any kind of activity that involves volunteers."@en ;
    dc:description "Volunteering Activity"@en ;
.

### Object Properties
:activityOrganisation
    a owl:ObjectProperty ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    rdfs:subPropertyOf :organisation ;
    owl:inverseOf :organisationActivity ;
    rdfs:domain :Activity ;
    rdfs:range :Organisation ;
    rdfs:label "activity has organisation"@en ;
.

:activityRole
    a owl:ObjectProperty ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    rdfs:subPropertyOf :role ;
    owl:inverseOf :roleActivity ;
    rdfs:domain :Activity ;
    rdfs:range :Role ;
    rdfs:label "activity has role"@en ;
.

:activitySession
    a owl:ObjectProperty ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    rdfs:subPropertyOf :session ;
    owl:inverseOf :sessionActivity ;
    rdfs:domain :Activity ;
    rdfs:range :Session ;
    rdfs:label "activity has session"@en ;
.


### Datatype Properties
:activityTitle
    a owl:DatatypeProperty ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    rdfs:subPropertyOf :title ;
    rdfs:domain :Activity ;
    rdfs:label "activity has title"@en ;
.

:activityDescription
    a owl:DatatypeProperty ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    rdfs:subPropertyOf :description ;
    rdfs:domain :Activity ;
    rdfs:label "activity has description"@en ;
.

:activityImage
    a owl:DatatypeProperty ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    rdfs:subPropertyOf :image ;
    rdfs:domain :Activity ;
    rdfs:label "activity has image"@en ;
.

:activityRequiresEmergencyParticipation
    a owl:DatatypeProperty ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    rdfs:subPropertyOf :requiresEmergencyParticipation ; 
    rdfs:domain :Activity ;
    rdfs:range xsd:boolean ;
    rdfs:label "activity requires emergency participation"@en ;
.

# Volunteering vocabulary

## Namespaces
### Ontology Base URI
prefix :                <https://ns.volunteeringdata.io/>

### Core W3C ontologies (OWL 2 reserved vocabulary)
prefix rdf:             <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
prefix rdfs:            <http://www.w3.org/2000/01/rdf-schema#>
prefix owl:             <http://www.w3.org/2002/07/owl#>
prefix xsd:             <http://www.w3.org/2001/XMLSchema#>

### Other namespaces used
prefix dc:              <http://purl.org/dc/terms/>
prefix geo:             <http://www.w3.org/2003/01/geo/wgs84_pos#>
prefix geosparql:       <http://www.opengis.net/ont/geosparql#>
prefix skos:            <http://www.w3.org/2004/02/skos/core#>
prefix time:            <http://www.w3.org/2006/time#>
prefix vcard:           <http://www.w3.org/2006/vcard/ns#>
prefix vann:            <http://purl.org/vocab/vann/>


## Location Class
:Location
    a owl:Class ;
    rdfs:subClassOf geo:SpatialThing, geosparql:SpatialObject ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    rdfs:label "Location"@en ;
    rdfs:comment "Any location related to volunteering activities."@en ;
    dc:description "Volunteering Activity Location"@en ;
.


### Object Properties
:locationSession
    a owl:ObjectProperty ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    rdfs:domain :Location ;
    rdfs:range :Session ;
    rdfs:label "session has location"@en ;
.


### Datatype Properties
:locationName
    a owl:DatatypeProperty ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    rdfs:subPropertyOf :name ;
    rdfs:domain :Location ;
    rdfs:label "location has name"@en ;
.

:locationAddress
    a owl:DatatypeProperty ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    rdfs:subPropertyOf :address ;
    rdfs:domain :Location ;
    rdfs:label "location has address"@en ;
.

:locationGeometry
    a owl:DatatypeProperty ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    rdfs:subPropertyOf :geometry ;
    rdfs:domain :Location ;
    rdfs:label "location has Geometry"@en ;
.

:locationLatitude
    a owl:DatatypeProperty ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    rdfs:subPropertyOf :latitude ;
    rdfs:domain :Location ;
    rdfs:label "location has latitude"@en ;
.

:locationLongitude
    a owl:DatatypeProperty ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    rdfs:subPropertyOf :longitude ;
    rdfs:domain :Location ;
    rdfs:label "location has longitude"@en ;
.

# Volunteering vocabulary

## Namespaces
### Ontology Base URI
prefix :                <https://ns.volunteeringdata.io/>

### Core W3C ontologies (OWL 2 reserved vocabulary)
prefix rdf:             <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
prefix rdfs:            <http://www.w3.org/2000/01/rdf-schema#>
prefix owl:             <http://www.w3.org/2002/07/owl#>
prefix xsd:             <http://www.w3.org/2001/XMLSchema#>

### Other namespaces used
prefix dc:              <http://purl.org/dc/terms/>
prefix geo:             <http://www.w3.org/2003/01/geo/wgs84_pos#>
prefix geosparql:       <http://www.opengis.net/ont/geosparql#>
prefix og:              <http://ogp.me/ns#>
prefix skos:            <http://www.w3.org/2004/02/skos/core#>
prefix time:            <http://www.w3.org/2006/time#>
prefix vcard:           <http://www.w3.org/2006/vcard/ns#>
prefix vann:            <http://purl.org/vocab/vann/>


## Ontology
<https://ns.volunteeringdata.io/>
    a owl:Ontology ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    rdfs:label "Volunteering and Social Action Ontology"@en ;
    dc:title "Volunteering and Social Action Ontology"@en ;
    dc:description "Defines a vocabulary to describe volunteering activities, volunteer-involving organisations and volunteering management systems."@en ;
    dc:issued "2025-11-20"^^xsd:date ;
    owl:versionIRI <https://ns.volunteeringdata.io/> ;
    owl:versionInfo "2026-03-12" ;
    vann:preferredNamespacePrefix "volunteering" ;
    vann:preferredNamespaceUri "https://ns.volunteeringdata.io/"^^xsd:anyURI ;
    rdfs:seeAlso <https://standard.volunteeringdata.io/ontology/> ;
.


### Object Properties
:activity
    a owl:ObjectProperty ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    rdfs:range :Activity ;
    rdfs:label "has activity"@en ;
.

:location
    a owl:ObjectProperty ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    rdfs:subPropertyOf geo:location ;
    rdfs:range :Location ;
    rdfs:label "has location"@en ;
.

:organisation
    a owl:ObjectProperty ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    rdfs:range :Organisation ;
    rdfs:label "has organisation"@en ;
.

:relatedConcept
    a owl:ObjectProperty ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    rdfs:range skos:Concept ;
    rdfs:label "has related concept"@en ;
.

:role
    a owl:ObjectProperty ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    rdfs:range :Role ;
    rdfs:label "has role"@en ;
.

:session
    a owl:ObjectProperty ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    rdfs:range :Session ;
    rdfs:label "has session"@en ;
.

:time
    a owl:ObjectProperty ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    rdfs:range :Time ;
    rdfs:label "has time"@en ;
.


## Datatype Properties
:address
    a owl:DatatypeProperty ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    rdfs:label "has address"@en ;
.

:allowsRemoteParticipation
    a owl:DatatypeProperty ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    rdfs:label "allows remote participation"@en ;
.

:applyLink
    a owl:DatatypeProperty ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    rdfs:label "has apply link"@en ;
.

:charityNumber
    a owl:DatatypeProperty ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    rdfs:label "has charity number"@en ;
.

:commitment
    a owl:DatatypeProperty ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    rdfs:label "has commitment"@en ;
    rdfs:comment "Free text description of the expected commitment to the role (e.g. 4 hours per week)."@en ;
.

:description
    a owl:DatatypeProperty ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    rdfs:subPropertyOf dc:description ;
    rdfs:label "has description"@en ;
.

:geometry
    a owl:DatatypeProperty ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    rdfs:subPropertyOf geosparql:hasGeometry ;
    rdfs:label "has Geometry"@en ;
    rdfs:comment "A geometry represents the spatial extent of a location (see OGC GeoSPARQL)."@en ;
    rdfs:seeAlso <https://opengeospatial.github.io/ogc-geosparql/> ;
.

:image
    a owl:DatatypeProperty ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    rdfs:subPropertyOf og:image ;
    rdfs:label "has Image"@en ;
    rdfs:comment "An image URL which can be used to present something related to volunteering."@en ;
    rdfs:seeAlso <https://opengeospatial.github.io/ogc-geosparql/> ;
.

:latitude
    a owl:DatatypeProperty ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    rdfs:subPropertyOf geo:lat ;
    rdfs:label "has latitude"@en ;
    rdfs:comment "The WGS84 latitude of a SpatialThing in decimal degrees (see WGS84 Geo Positioning)."@en ;
    rdfs:seeAlso <https://www.w3.org/2003/01/geo/wgs84_pos> ;
.

:longitude
    a owl:DatatypeProperty ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    rdfs:subPropertyOf geo:long ;
    rdfs:label "has longitude"@en ;
    rdfs:comment "The WGS84 longitude of a SpatialThing in decimal degrees (see WGS84 Geo Positioning)."@en ;
    rdfs:seeAlso <https://www.w3.org/2003/01/geo/wgs84_pos> ;
.

:maximumAge
    a owl:DatatypeProperty ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    rdfs:label "has maximum age"@en ;
.

:minimumAge
    a owl:DatatypeProperty ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    rdfs:label "has minimum age"@en ;
.

:name
    a owl:DatatypeProperty ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    rdfs:label "has name"@en ;
.

:requiresEmergencyParticipation
    a owl:DatatypeProperty ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    rdfs:label "requires emergency participation"@en ;
.

:title
    a owl:DatatypeProperty ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    rdfs:label "has title"@en ;
.

:website
    a owl:DatatypeProperty ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    rdfs:label "has website"@en ;
.

# Volunteering vocabulary

## Namespaces
### Ontology Base URI
prefix :                <https://ns.volunteeringdata.io/>

### Core W3C ontologies (OWL 2 reserved vocabulary)
prefix rdf:             <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
prefix rdfs:            <http://www.w3.org/2000/01/rdf-schema#>
prefix owl:             <http://www.w3.org/2002/07/owl#>
prefix xsd:             <http://www.w3.org/2001/XMLSchema#>

### Other namespaces used
prefix dc:              <http://purl.org/dc/terms/>
prefix skos:            <http://www.w3.org/2004/02/skos/core#>
prefix time:            <http://www.w3.org/2006/time#>
prefix vcard:           <http://www.w3.org/2006/vcard/ns#>
prefix vann:            <http://purl.org/vocab/vann/>


# Class
:Organisation
    a owl:Class ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    rdfs:label "Organisation"@en ;
    rdfs:comment "Any organisation running activities that involve volunteers."@en ;
    dc:description "Volunteer-Involving Organisation"@en ;
.


# Object Properties
:organisationActivity
    a owl:ObjectProperty ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    rdfs:subPropertyOf :activity ;
    owl:inverseOf :activityOrganisation ;
    rdfs:domain :Organisation ;
    rdfs:range :Activity ;
    rdfs:label "organisation has activity"@en ;
.

:organisationCause
    a owl:ObjectProperty ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    rdfs:subPropertyOf :cause ;
    owl:inverseOf :causeOrganisation ;
    rdfs:domain :Organisation ;
    rdfs:range :Cause ;
    rdfs:label "organisation has charitable cause"@en ;
.


# Datatype Properties
:organisationName
    a owl:DatatypeProperty ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    rdfs:subPropertyOf :name ;
    rdfs:domain :Organisation ;
    rdfs:label "organisation has name"@en ;
.

:organisationDescription
    a owl:DatatypeProperty ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    rdfs:subPropertyOf :description ;
    rdfs:domain :Organisation ;
    rdfs:label "organisation has description"@en ;
.

:organisationImage
    a owl:DatatypeProperty ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    rdfs:subPropertyOf :image ;
    rdfs:domain :Organisation ;
    rdfs:label "organisation has image"@en ;
.

:organisationWebsite
    a owl:DatatypeProperty ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    rdfs:subPropertyOf :website ;
    rdfs:domain :Organisation ;
    rdfs:label "organisation has website"@en ;
.

:organisationCharityNumber
    a owl:DatatypeProperty ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    rdfs:subPropertyOf :charityNumber ;
    rdfs:domain :Organisation ;
    rdfs:label "organisation has charity number"@en ;
.

# Volunteering vocabulary

## Namespaces
### Ontology Base URI
prefix :                <https://ns.volunteeringdata.io/>

### Core W3C ontologies (OWL 2 reserved vocabulary)
prefix rdf:             <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
prefix rdfs:            <http://www.w3.org/2000/01/rdf-schema#>
prefix owl:             <http://www.w3.org/2002/07/owl#>
prefix xsd:             <http://www.w3.org/2001/XMLSchema#>

### Other namespaces used
prefix dc:              <http://purl.org/dc/terms/>
prefix skos:            <http://www.w3.org/2004/02/skos/core#>
prefix time:            <http://www.w3.org/2006/time#>
prefix vcard:           <http://www.w3.org/2006/vcard/ns#>
prefix vann:            <http://purl.org/vocab/vann/>


## Role Class
:Role
    a owl:Class ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    rdfs:label "Role"@en ;
    rdfs:comment "Any kind of role related to a volunteering activity."@en ;
    dc:description "Volunteering Role"@en ;
.

### Object Properties
:roleAccessibility
    a owl:ObjectProperty ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    rdfs:subPropertyOf :accessibility ;
    owl:inverseOf :accessibilityRole ;
    rdfs:domain :Role ;
    rdfs:range :Accessibility ;
    rdfs:label "role has accessibility"@en ;
.

:roleActivity
    a owl:ObjectProperty ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    rdfs:subPropertyOf :activity ;
    owl:inverseOf :activityRole ;
    rdfs:domain :Role ;
    rdfs:range :Activity ;
    rdfs:label "role has activity"@en ;
.

:roleRequirement
    a owl:ObjectProperty ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    rdfs:subPropertyOf :requirement ;
    owl:inverseOf :requirementRole ;
    rdfs:domain :Role ;
    rdfs:range :Requirement ;
    rdfs:label "role has requirement"@en ;
.

:roleReward
    a owl:ObjectProperty ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    rdfs:subPropertyOf :reward ;
    owl:inverseOf :rewardRole ;
    rdfs:domain :Role ;
    rdfs:range :Reward ;
    rdfs:label "role has reward"@en ;
.

:roleSkill
    a owl:ObjectProperty ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    rdfs:subPropertyOf :skill ;
    owl:inverseOf :skillRole ;
    rdfs:domain :Role ;
    rdfs:range :Skill ;
    rdfs:label "role has skill"@en ;
.


### Datatype Properties
:roleAllowsRemoteParticipation
    a owl:DatatypeProperty ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    rdfs:subPropertyOf :allowsRemoteParticipation ; 
    rdfs:domain :Role ;
    rdfs:range xsd:boolean ;
    rdfs:label "role allows remote participation"@en ;
.

:roleApplyLink
    a owl:DatatypeProperty ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    rdfs:subPropertyOf :applyLink ;
    rdfs:domain :Role ;
    rdfs:label "role has apply link"@en ;
.

:roleCommitment
    a owl:DatatypeProperty ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    rdfs:subPropertyOf :commitment ;
    rdfs:domain :Role ;
    rdfs:label "role has commitment"@en ;
.

:roleDescription
    a owl:DatatypeProperty ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    rdfs:subPropertyOf :description ;
    rdfs:domain :Role ;
    rdfs:label "role has description"@en ;
.

:roleMaximumAge
    a owl:DatatypeProperty ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    rdfs:subPropertyOf :maximumAge ;
    rdfs:domain :Role ;
    rdfs:label "role has maximum age"@en ;
.

:roleMinimumAge
    a owl:DatatypeProperty ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    rdfs:subPropertyOf :minimumAge ;
    rdfs:domain :Role ;
    rdfs:label "role has minimum age"@en ;
.

:roleTitle
    a owl:DatatypeProperty ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    rdfs:subPropertyOf :title ;
    rdfs:domain :Role ;
    rdfs:label "role has title"@en ;
.

# Volunteering vocabulary

## Namespaces
### Ontology Base URI
prefix :                <https://ns.volunteeringdata.io/>

### Core W3C ontologies (OWL 2 reserved vocabulary)
prefix rdf:             <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
prefix rdfs:            <http://www.w3.org/2000/01/rdf-schema#>
prefix owl:             <http://www.w3.org/2002/07/owl#>
prefix xsd:             <http://www.w3.org/2001/XMLSchema#>

### Other namespaces used
prefix dc:              <http://purl.org/dc/terms/>
prefix skos:            <http://www.w3.org/2004/02/skos/core#>
prefix time:            <http://www.w3.org/2006/time#>
prefix vcard:           <http://www.w3.org/2006/vcard/ns#>
prefix vann:            <http://purl.org/vocab/vann/>


## Class
:Session
    a owl:Class ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    rdfs:label "Session"@en ;
    rdfs:comment "A session describes a time and place for an activity that involves volunteers."@en ;
    dc:description "Volunteering Activity Session"@en ;
.

### Object Properties
:sessionActivity
    a owl:ObjectProperty ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    rdfs:subPropertyOf :activity ;
    owl:inverseOf :activitySession ;
    rdfs:domain :Session ;
    rdfs:range :Activity ;
    rdfs:label "session has activity"@en ;
.

:sessionLocation
    a owl:ObjectProperty ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    rdfs:subPropertyOf :location ;
    owl:inverseOf :locationSession ;
    rdfs:domain :Session ;
    rdfs:range :Location ;
    rdfs:label "session has location"@en ;
.

:sessionTime
    a owl:ObjectProperty ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    rdfs:subPropertyOf :time ;
    owl:inverseOf :timeSession ;
    rdfs:domain :Session ;
    rdfs:range :Time ;
    rdfs:label "session has time"@en ;
.


# Volunteering vocabulary

## Namespaces
### Ontology Base URI
prefix :                <https://ns.volunteeringdata.io/>

### Core W3C ontologies (OWL 2 reserved vocabulary)
prefix rdf:             <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
prefix rdfs:            <http://www.w3.org/2000/01/rdf-schema#>
prefix owl:             <http://www.w3.org/2002/07/owl#>
prefix xsd:             <http://www.w3.org/2001/XMLSchema#>

### Other namespaces used
prefix dc:              <http://purl.org/dc/terms/>
prefix skos:            <http://www.w3.org/2004/02/skos/core#>
prefix time:            <http://www.w3.org/2006/time#>
prefix vcard:           <http://www.w3.org/2006/vcard/ns#>
prefix vann:            <http://purl.org/vocab/vann/>


## Taxonomy Class
:Taxonomy
    a skos:ConceptScheme ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    skos:hasTopConcept :Accessibility, :Cause, :Requirement, :Reward, :Skill ;
    rdfs:label "Taxonomy"@en ;
    dc:title "Volunteering Taxonomy"@en ;
    dc:description "The taxonomy of concepts related to volunteering activities."@en ;
.


### Super property
:relatedConcept
    a owl:ObjectProperty ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    rdfs:range :Concept ;
    rdfs:label "has related concept"@en ;
.


### Object Properties
:accessbibility
    a owl:ObjectProperty ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    rdfs:subPropertyOf :relatedConcept ;
    rdfs:label "has accessibility information"@en ;
.

:accessibilityRole
    a owl:ObjectProperty ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    rdfs:subPropertyOf :role ;
    owl:inverseOf :roleAccessibility ;
    rdfs:domain :Accessibility ;
    rdfs:range :Role ;
    rdfs:label "accessibility information has role"@en ;
.

:cause
    a owl:ObjectProperty ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    rdfs:subPropertyOf :relatedConcept ;
    rdfs:label "has cause"@en ;
.

:causeOrganisation
    a owl:ObjectProperty ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    rdfs:subPropertyOf :organisation ;
    owl:inverseOf :organisationCause ;
    rdfs:domain :Cause ;
    rdfs:range :Organisation ;
    rdfs:label "charitable cause has organisation"@en ;
.

:requirement
    a owl:ObjectProperty ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    rdfs:subPropertyOf :relatedConcept ;
    rdfs:label "has requirement"@en ;
.

:requirementRole
    a owl:ObjectProperty ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    rdfs:subPropertyOf :role ;
    owl:inverseOf :roleRequirement ;
    rdfs:domain :Requirement ;
    rdfs:range :Role ;
    rdfs:label "requirement has role"@en ;
.

:reward
    a owl:ObjectProperty ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    rdfs:subPropertyOf :relatedConcept ;
    rdfs:label "has reward"@en ;
.

:rewardRole
    a owl:ObjectProperty ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    rdfs:subPropertyOf :role ;
    owl:inverseOf :roleReward ;
    rdfs:domain :Reward ;
    rdfs:range :Role ;
    rdfs:label "reward has role"@en ;
.

:skill
    a owl:ObjectProperty ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    rdfs:subPropertyOf :relatedConcept ;
    rdfs:label "has skill"@en ;
.

:skillRole
    a owl:ObjectProperty ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    rdfs:subPropertyOf :role ;
    owl:inverseOf :roleSkill ;
    rdfs:domain :Skill ;
    rdfs:range :Role ;
    rdfs:label "skill has role"@en ;
.

# Volunteering vocabulary

## Namespaces
### Ontology Base URI
prefix :                <https://ns.volunteeringdata.io/>

### Core W3C ontologies (OWL 2 reserved vocabulary)
prefix rdfs:            <http://www.w3.org/2000/01/rdf-schema#>
prefix owl:             <http://www.w3.org/2002/07/owl#>
prefix xsd:             <http://www.w3.org/2001/XMLSchema#>

### Other namespaces used
prefix dc:              <http://purl.org/dc/terms/>
prefix skos:            <http://www.w3.org/2004/02/skos/core#>
prefix time:            <http://www.w3.org/2006/time#>
prefix vcard:           <http://www.w3.org/2006/vcard/ns#>
prefix vann:            <http://purl.org/vocab/vann/>


## Time Class
:Time
    a owl:Class ;
    rdfs:subClassOf time:TemporalEntity ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    rdfs:label "Time"@en ;
    rdfs:comment "Any time information related to volunteering activities modeled as a OWL time temporal entity."@en ;
    dc:description "Volunteering Activity Time Information"@en ;
.

:WeekdayTimePeriod
    a owl:Class ;
    rdfs:subClassOf :Time ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    rdfs:comment "A predefined time period within a specific day of the week (morning, afternoon or evening)."@en ;
    rdfs:label "Weekday Time Period"@en ;
.

### Object Properties
:timeSession
    a owl:ObjectProperty ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    rdfs:subPropertyOf :session ;
    owl:inverseOf :sessionTime ;
    rdfs:domain :Time ;
    rdfs:range :Session ;
    rdfs:label "time has session"@en ;
.


## Predefined Temporal Entities
:MondayMorning
    a time:TemporalEntity, :Time, :WeekdayTimePeriod ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    rdfs:label "Monday morning"@en ;
    time:hasBeginning [
        a time:Instant ;
        time:inDateTime [
            a time:GeneralDateTimeDescription ;
            time:dayOfWeek time:Monday ;
            time:hour "6"^^xsd:nonNegativeInteger ;
            time:minute "0"^^xsd:nonNegativeInteger ;
            time:second "0"^^xsd:nonNegativeInteger ;
        ] ;
    ] ;
    time:hasEnd [
        a time:Instant ;
        time:inDateTime [
            a time:GeneralDateTimeDescription ;
            time:dayOfWeek time:Monday ;
            time:hour "12"^^xsd:nonNegativeInteger ;
            time:minute "0"^^xsd:nonNegativeInteger ;
            time:second "0"^^xsd:nonNegativeInteger ;
        ] ;
    ] ;
.

:MondayAfternoon
    a time:TemporalEntity, :Time, :WeekdayTimePeriod ;
