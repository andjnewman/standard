    skos:altLabel "Belief"@en, "Churches"@en, "Religious"@en, "Ideology"@en ;
    skos:definition "Volunteering in religious and faith-based organizations and spiritual community services."@en ;
    skos:broader :Cause ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
.

:ResidentsDisadvantagedNeighbourhoods
    a skos:Concept ;
    skos:prefLabel "Residents of Disadvantaged Neighbourhoods"@en ;
    skos:altLabel "Vulerable groups"@en, "Local Poverty"@en, "Deprived Areas"@en, "Deprived Populations"@en ;
    skos:definition "Volunteering supporting residents of disadvantaged neighbourhoods and deprived communities."@en ;
    skos:broader :LocalCommunity ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
.

:SensoryImpairment
