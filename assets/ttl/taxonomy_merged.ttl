    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
.

:PersonalPreparedness
    a skos:Concept ;
    skos:prefLabel "Personal preparedness (water, snacks, medication)"@en ;
    skos:broader :PhysicalPracticalReadiness ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
.

