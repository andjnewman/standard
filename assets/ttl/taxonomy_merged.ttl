
# Volunteering vocabulary

## Namespaces
### Ontology Base URI
prefix :                <https://ns.volunteeringdata.io/>

### Core W3C ontologies (OWL 2 reserved vocabulary)
prefix rdf:             <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
prefix rdfs:            <http://www.w3.org/2000/01/rdf-schema#>
prefix owl:             <http://www.w3.org/2002/07/owl#>
prefix xsd:             <http://www.w3.org/2001/XMLSchema#>

### Other namespaces used
prefix dc:              <http://purl.org/dc/terms/>
prefix skos:            <http://www.w3.org/2004/02/skos/core#>
prefix time:            <http://www.w3.org/2006/time#>
prefix vcard:           <http://www.w3.org/2006/vcard/ns#>
prefix vann:            <http://purl.org/vocab/vann/>


## Taxonomy top concept
:Accessibility
    a skos:Concept ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    skos:topConceptOf :Taxonomy ;
    skos:prefLabel "Accessibility"@en ;
    skos:definition "Any accessibility information related to volunteering activities."@en ;
.


### Taxonomy Hierarchy
:AgeRequirements
    a skos:Concept ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    skos:broader :Accessibility ;
    skos:inScheme :Taxonomy ;
    skos:prefLabel "Age Requirements" ;
    skos:definition "Any information regarding specific ages or ranges of ages required or disallowed from a activity." ;
.

:DigitalAccessibility
    a skos:Concept ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    skos:broader :Accessibility ;
    skos:inScheme :Taxonomy ;
    skos:prefLabel "Digital Accessibility"@en ;
    skos:definition "Any accessbility information regarding digital requirements for an activity"@en ;
.

:ExpensesPaid
    a skos:Concept ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    skos:broader :Accessibility ;
    skos:inScheme :Taxonomy ;
    skos:prefLabel "Expenses Paid" ;
    skos:definition "Any information regarding reimbursement for activity or role-related expenses.";
.

:LanguageRequirements
    a skos:Concept ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    skos:broader :Accessibility ;
    skos:inScheme :Taxonomy ;
    skos:prefLabel "Language Requirements" ;
    skos:definition "Any language information for an activity, including required language(s) and translation services available." ;
.

:PhysicalAccessibility
    a skos:Concept ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    skos:broader :Accessibility ;
    skos:inScheme :Taxonomy ;
    skos:prefLabel "Physical Accessibility"@en ;
    skos:definition "Any accessbibility information regarding physical ability required for an activity" ;
.


##Digital Accessibility Concepts
:WifiUsage
    a skos:Concept ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    skos:broader :Accessibility ;
    skos:inScheme :DigitalAccessibility ;
    skos:prefLabel "Wifi Usage" ;
    skos:definition "Any information on wifi usage necessary for a activity." ;
.

:TechnologyRequirements
    a skos:Concept ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    skos:broader :Accessibility ;
    skos:inScheme :DigitalAccessibility ;
    skos:prefLabel "Technology Requirements" ;
    skos:definition "Any information on devices (laptop, phone, smartphone) and software required for a activity." ;
.

:TechnologyAvailability
    a skos:Concept ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    skos:broader :Accessibility ;
    skos:inScheme :DigitalAccessibility ;
    skos:prefLabel "Technology Availability" ;
    skos:definition "Any information on supplementory accessiblity software available in activities (screen readers, captioning)." ;
.


##Physical Accessibility Concepts
:RemoteAccessibility
    a skos:Concept ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    skos:broader :Accessibility ;
    skos:inScheme :PhysicalAccessibility ;
    skos:prefLabel "Remote Accessibility" ;
    skos:definition "Any accomodations available for remote participation in an activity." ;
.

:BuildingAccessibilityFeatures
    a skos:Concept ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    skos:broader :Accessibility ;
    skos:inScheme :PhysicalAccessibility ;
    skos:prefLabel "Building Accessibility Features" ;
    skos:definition "Any information on building accessibility features for mobility aid users and accessible gender, faith, etc. rooms." ;
.

:PublicTransportAccess
    a skos:Concept ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    skos:broader :Accessibility ;
    skos:inScheme :PhysicalAccessibility ;
    skos:prefLabel "Public Transport Access" ;
    skos:definition "Any information on venue access via public transport lines." ;
.

:ParkingAvailability
    a skos:Concept ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    skos:broader :Accessibility ;
    skos:inScheme :PhysicalAccessibility ;
    skos:prefLabel "Parking Availability" ;
    skos:definition "Any information on parking availability and accessibility at the venue." ;
.

:ServiceAnimals
    a skos:Concept ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    skos:broader :Accessibility ;
    skos:inScheme :PhysicalAccessibility ;
    skos:prefLabel "Service Animals" ;
    skos:definition "Accessiblity information regarding usage of service animals in and around venue." ;
.

:VisualImpairment
    a skos:Concept ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    skos:broader :Accessibility ;
    skos:inScheme :PhysicalAccessibility ;
    skos:prefLabel "Visual Impairment" ;
    skos:definition "Any information on activities wherin visual impairments may be affected or accommodated." ;
.

:CareProfessionals
    a skos:Concept ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    skos:broader :Accessibility ;
    skos:inScheme :PhysicalAccessibility ;
    skos:prefLabel "Care Professionals" ;
    skos:definition "Any accommodations available for volunteers assisted by care professionals." ;
.

# Volunteering vocabulary

## Namespaces
### Ontology Base URI
prefix :                <https://ns.volunteeringdata.io/>

### Core W3C ontologies (OWL 2 reserved vocabulary)
prefix rdf:             <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
prefix rdfs:            <http://www.w3.org/2000/01/rdf-schema#>
prefix owl:             <http://www.w3.org/2002/07/owl#>
prefix xsd:             <http://www.w3.org/2001/XMLSchema#>

### Other namespaces used
prefix dc:              <http://purl.org/dc/terms/>
prefix skos:            <http://www.w3.org/2004/02/skos/core#>
prefix time:            <http://www.w3.org/2006/time#>
prefix vcard:           <http://www.w3.org/2006/vcard/ns#>
prefix vann:            <http://purl.org/vocab/vann/>


## Taxonomy top concept
:Cause
    a skos:Concept ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    skos:topConceptOf :Taxonomy ;
    skos:prefLabel "Cause"@en ;
    skos:definition "Any charitable cause related to volunteering activities."@en ;
.


## Cause Concepts
:AnimalWelfare
    a skos:Concept ;
    skos:prefLabel "Animal Welfare"@en ;
    skos:altLabel "Wildlife"@en, "Pets"@en, "Creatures"@en, "Mammals"@en ;
    skos:definition "Volunteering focused on the protection, care, and welfare of animals, including wildlife conservation, pet support, and creature advocacy."@en ;
    skos:broader :Cause ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
.

:AntiPoverty
    a skos:Concept ;
    skos:prefLabel "Anti-Poverty"@en ;
    skos:altLabel "Poverty Reduction"@en, "Tackling Poverty"@en ;
    skos:definition "Volunteering activities aimed at reducing poverty, supporting low-income households, and promoting economic empowerment."@en ;
    skos:broader :Cause ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
.

:ArtsAndCulture
    a skos:Concept ;
    skos:prefLabel "Arts and Culture"@en ;
    skos:altLabel "Culture"@en, "Society"@en, "Humanities"@en, "Music"@en, "Theatre"@en, "Dance"@en, "Graphic Arts"@en, "Crafts"@en ;
    skos:definition "Volunteering in artistic and cultural domains including music, theatre, dance, visual arts, crafts, and heritage preservation."@en ;
    skos:broader :Cause ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
.

:Care
    a skos:Concept ;
    skos:prefLabel "Care"@en ;
    skos:altLabel "Care Services"@en, "Care Providers"@en, "Counselling Support"@en, "Addiction Support"@en, "Social Care"@en, "Carers"@en, "Caregivers"@en, "Guardians"@en, "Live in carers"@en, "Home Carers"@en ;
    skos:definition "Volunteering providing care services, support to carers, counselling, and social care assistance."@en ;
    skos:broader :Cause ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
.

:CivilRights
    a skos:Concept ;
    skos:prefLabel "Civil Rights"@en ;
    skos:altLabel "Human Rights"@en, "Citizens Rights"@en, "Equality"@en, "Justice"@en ;
    skos:definition "Volunteering promoting human rights, civil liberties, equality, justice, and citizen empowerment."@en ;
    skos:broader :Cause ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
.

:Community
    a skos:Concept ;
    skos:prefLabel "Community"@en ;
    skos:altLabel "Community groups"@en, "Society"@en, "Local Public"@en ;
    skos:definition "Volunteering supporting community development, local initiatives, and strengthening of community groups."@en ;
    skos:broader :Cause ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
.

:CrimeSafety
    a skos:Concept ;
    skos:prefLabel "Crime / Safety"@en ;
    skos:altLabel "Protection"@en, "Security"@en, "Offences"@en, "Wrongdoing"@en ;
    skos:definition "Volunteering supporting crime prevention, public safety, victim support, and protection services."@en ;
    skos:broader :Cause ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
.

:CrimeExOffenders
    a skos:Concept ;
    skos:prefLabel "Crime & ex-offenders"@en ;
    skos:altLabel "Criminal Justice System"@en, "Prisons"@en ;
    skos:definition "Volunteering supporting offenders, ex-offenders, rehabilitation programmes, and the criminal justice system."@en ;
    skos:broader :CrimeSafety ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
.

:DevelopmentEmergencyRelief
    a skos:Concept ;
    skos:prefLabel "Development & emergency relief"@en ;
    skos:altLabel "Disaster emergency relief"@en, "Emergency Services"@en, "Emergency Support"@en, "Rescue Services"@en, "Responders"@en, "Natural Disasters"@en, "Urgent problem"@en, "Accidents"@en, "Tragedy"@en, "Crisis"@en ;
    skos:definition "Volunteering in emergency response, disaster relief, humanitarian aid, and crisis management."@en ;
    skos:broader :Cause ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
.

:Disability
    a skos:Concept ;
    skos:prefLabel "Disability"@en ;
    skos:altLabel "Disabled People"@en, "Diabled Groups"@en, "Impairment"@en ;
    skos:definition "Volunteering supporting people with disabilities, accessibility advocacy, and disability services."@en ;
    skos:broader :Cause ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
.

:EducationLanguages
    a skos:Concept ;
    skos:prefLabel "Education & languages"@en ;
    skos:altLabel "Schooling"@en, "Further Education"@en, "Tongues"@en, "Dialects"@en ;
    skos:definition "Volunteering in education programmes, language support, literacy, and educational development."@en ;
    skos:broader :Cause ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
.

:Environment
    a skos:Concept ;
    skos:prefLabel "Environment"@en ;
    skos:altLabel "Natural World"@en, "Surroundings"@en, "Nature"@en, "Planet"@en, "Conservation"@en, "Natural Environment"@en, "Ecosystem"@en, "Climate Change"@en, "Atmosphere"@en, "Clean"@en, "Sustainability"@en ;
    skos:definition "Volunteering addressing environmental conservation, climate change, sustainability, and natural resource protection."@en ;
    skos:broader :Cause ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
.

:EthnicMinorities
    a skos:Concept ;
    skos:prefLabel "Ethnic Minorities"@en ;
    skos:altLabel "Ethnic Groups"@en, "Ethnic Communities"@en, "Racial Minorities"@en, "Racial Groups"@en ;
    skos:definition "Volunteering supporting ethnic minority groups, racial equality, and cultural integration."@en ;
    skos:broader :Cause ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
.

:Families
    a skos:Concept ;
    skos:prefLabel "Families"@en ;
    skos:altLabel "Relatives"@en, "Households"@en, "Family Members"@en, "Loved Ones"@en ;
    skos:definition "Volunteering supporting families, household welfare, and family services."@en ;
    skos:broader :Cause ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
.

:GenderSexuality
    a skos:Concept ;
    skos:prefLabel "Gender / Sexuality"@en ;
    skos:altLabel "Gender Identity"@en, "Sexual Identity"@en, "Sexual Orientation"@en ;
    skos:definition "Volunteering supporting gender identity, sexual orientation equality, and LGBTIQ+ advocacy."@en ;
    skos:broader :Cause ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
.

:GeneralPublic
    a skos:Concept ;
    skos:prefLabel "General Public"@en ;
    skos:altLabel "People"@en, "General Population"@en, "Local Community"@en ;
    skos:definition "Volunteering serving the general public and broader populations."@en ;
    skos:broader :Cause ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
.

:Health
    a skos:Concept ;
    skos:prefLabel "Health"@en ;
    skos:altLabel "Wellbeing"@en, "Wellness"@en, "Public Health"@en, "Hospital"@en, "Health Service"@en, "Health Providers"@en ;
    skos:definition "Volunteering in healthcare, health promotion, public health, and wellness services."@en ;
    skos:broader :Cause ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
.

:Heritage
    a skos:Concept ;
    skos:prefLabel "Heritage"@en ;
    skos:altLabel "Exhibitions"@en, "Galleries"@en, "History"@en, "Institutions"@en, "Museums"@en ;
    skos:definition "Volunteering in heritage preservation, museums, galleries, historical institutions, and cultural conservation."@en ;
    skos:broader :Cause ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
.

:Housing
    a skos:Concept ;
    skos:prefLabel "Housing"@en ;
    skos:altLabel "Housing Associations"@en, "Sheltered Housing"@en, "Accommodation"@en, "Displacement"@en, "Homeless People"@en ;
    skos:definition "Volunteering supporting housing provision, homelessness prevention, and accommodation services."@en ;
    skos:broader :Cause ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
.

:Illness
    a skos:Concept ;
    skos:prefLabel "Illness"@en ;
    skos:altLabel "Patients"@en, "Sick People"@en, "Sufferers"@en, "People with Ill Health"@en ;
    skos:definition "Volunteering supporting people with illnesses, patient care, and health condition management."@en ;
    skos:broader :Health ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
.

:InCare
    a skos:Concept ;
    skos:prefLabel "In Care"@en ;
    skos:altLabel "Care Homes"@en, "Hospitalised"@en, "Foster Care"@en, "Existing"@en, "Children Social Care"@en, "Leaving Care"@en ;
    skos:definition "Volunteering in care institutions, care homes, foster care, and supporting those in state care."@en ;
    skos:broader :Care ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
.

:LearningDisabilities
    a skos:Concept ;
    skos:prefLabel "Learning Disabilities"@en ;
    skos:altLabel "Learning Difficulties"@en, "Learning Impairment"@en ;
    skos:definition "Volunteering supporting people with learning disabilities and learning difficulties."@en ;
    skos:broader :Disability ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
.

:LGBT
    a skos:Concept ;
    skos:prefLabel "LGBT"@en ;
    skos:altLabel "Lesbian"@en, "Gay"@en, "Bisexual"@en, "Transgender"@en, "LGBT Community"@en, "LGBTQ"@en ;
    skos:definition "Volunteering supporting lesbian, gay, bisexual, and transgender communities and LGBTQ+ rights."@en ;
    skos:broader :Cause ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
.

:LiteracyNeeds
    a skos:Concept ;
    skos:prefLabel "Literacy Needs"@en ;
    skos:altLabel "Literacy Skills"@en, "Literacy Difficulties"@en, "Literacy Support"@en, "Learning"@en, "Training"@en, "Reading"@en, "Writing"@en ;
    skos:definition "Volunteering addressing literacy support, reading and writing development, and literacy skills training."@en ;
    skos:broader :EducationLanguages ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
.

:LocalAuthority
    a skos:Concept ;
    skos:prefLabel "Local Authority"@en ;
    skos:altLabel "Local Council"@en, "Local Government"@en, "Council Office"@en, "Town Council"@en ;
    skos:definition "Volunteering with local government, councils, and local authority services."@en ;
    skos:broader :Community ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
.

:LocalCommunity
    a skos:Concept ;
    skos:prefLabel "Local Community"@en ;
    skos:altLabel "Neighbourhood"@en, "Community Centres"@en, "Local Population"@en, "Village"@en ;
    skos:definition "Volunteering supporting local community development, neighbourhood initiatives, and village services."@en ;
    skos:broader :Community ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
.

:LoneParents
    a skos:Concept ;
    skos:prefLabel "Lone Parents"@en ;
    skos:altLabel "Single Parents"@en, "Single Mothers"@en, "Single Fathers"@en, "One Parent Families"@en, "Single Parent Families"@en ;
    skos:definition "Volunteering supporting single parents, lone parent families, and associated support services."@en ;
    skos:broader :Families ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
.

:LowIncomeHouseholds
    a skos:Concept ;
    skos:prefLabel "Low Income Households"@en ;
    skos:altLabel "Family Poverty"@en, "Child Poverty"@en, "Low Earnings"@en ;
    skos:definition "Volunteering addressing low income household support, family poverty, and child poverty reduction."@en ;
    skos:broader :AntiPoverty ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
.

:MensGroups
    a skos:Concept ;
    skos:prefLabel "Mens Groups"@en ;
    skos:altLabel "Mens Support Groups"@en, "Male Peer Support"@en, "Male Groups"@en ;
    skos:definition "Volunteering in men's groups, male peer support, and male-focused community services."@en ;
    skos:broader :Cause ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
.

:MentalHealth
    a skos:Concept ;
    skos:prefLabel "Mental Health"@en ;
    skos:altLabel "Mental Wellbeing"@en, "Emotional Health"@en, "Psychological Health"@en, "Behavioral Health"@en ;
    skos:definition "Volunteering in mental health support, mental wellbeing, and psychological health services."@en ;
    skos:broader :Health ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
.

:OffendersAndExOffenders
    a skos:Concept ;
    skos:prefLabel "Offenders and Ex-Offenders"@en ;
    skos:altLabel "Prisoners"@en, "Former Offenders"@en, "Offender Rehabilitation"@en, "Criminals"@en ;
    skos:definition "Volunteering with offenders, ex-offenders, prisoners, and offender rehabilitation programmes."@en ;
    skos:broader :CrimeExOffenders ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
.

:OlderPeople
    a skos:Concept ;
    skos:prefLabel "Older People"@en ;
    skos:altLabel "Ageing"@en, "Senior Citizens"@en, "Pensioners"@en, "Old Adults"@en, "Old People"@en, "Elderly"@en, "Old"@en, "Seniors"@en ;
    skos:definition "Volunteering supporting elderly and older people, senior citizens, and age-related services."@en ;
    skos:broader :Cause ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
.

:OverseasAidDevelopingWorld
