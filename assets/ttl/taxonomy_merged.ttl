    skos:definition "Volunteering in sports, recreational activities, outdoor experiences, and physical activity promotion."@en ;
    skos:broader :Cause ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
.

:SubstanceAbuse
    a skos:Concept ;
    skos:prefLabel "Substance Abuse"@en ;
    skos:altLabel "Addiction"@en, "Drug Dependency"@en, "Drugs"@en, "Alcohol Dependency"@en, "Alcohol Issues"@en ;
