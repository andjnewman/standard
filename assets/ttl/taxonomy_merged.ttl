    skos:broader :TransportMobilityAssets ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
.

:VehicleTowCapability
    a skos:Concept ;
    skos:prefLabel "Vehicle with tow capability"@en ;
    skos:broader :TransportMobilityAssets ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
.

:VanOrPeopleCarrier
    a skos:Concept ;
    skos:prefLabel "Access to a van or people-carrier"@en ;
    skos:broader :TransportMobilityAssets ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
.

:TransportEquipmentSupplies
    a skos:Concept ;
    skos:prefLabel "Ability to transport equipment or supplies"@en ;
    skos:broader :TransportMobilityAssets ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
.

:BicyclesCargoBikes
    a skos:Concept ;
    skos:prefLabel "Access to bicycles or cargo bikes"@en ;
    skos:broader :TransportMobilityAssets ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
.

:Boat
    a skos:Concept ;
    skos:prefLabel "Boat"@en ;
    skos:broader :TransportMobilityAssets ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
.

:Hovercraft
    a skos:Concept ;
