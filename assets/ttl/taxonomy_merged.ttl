    skos:altLabel "Physical Impairment"@en ;
    skos:definition "Volunteering supporting people with physical disabilities and physical impairments."@en ;
    skos:broader :Disability ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
.

:RefugeesAsylumSeekers
    a skos:Concept ;
    skos:prefLabel "Refugees / Asylum Seekers"@en ;
    skos:altLabel "Evacuees"@en, "Displaced People"@en, "Migrants"@en ;
