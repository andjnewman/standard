    skos:broader :PersonalEquipment ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
.

:HighVisibilityVest
    a skos:Concept ;
    skos:prefLabel "High-visibility vest"@en ;
    skos:broader :PersonalEquipment ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
.

:HeadtorchFlashlight
    a skos:Concept ;
    skos:prefLabel "Headtorch or flashlight"@en ;
    skos:broader :PersonalEquipment ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
.

:PhonePowerBank
    a skos:Concept ;
    skos:prefLabel "Phone + power bank"@en ;
    skos:broader :PersonalEquipment ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
.

:FirstAidKit
    a skos:Concept ;
    skos:prefLabel "Small personal first aid kit"@en ;
    skos:broader :PersonalEquipment ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
.

:WaterBottle
    a skos:Concept ;
    skos:prefLabel "Water bottle"@en ;
    skos:broader :PersonalEquipment ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
.

:TransportMobilityAssets
    a skos:Concept ;
