### Community & Environment Knowledge Category
:CommunityEnvironmentKnowledge
    a skos:Concept ;
    skos:prefLabel "Community & Environment Knowledge"@en ;
    skos:definition "Knowledge and awareness of local community, environment, and support systems."@en ;
    skos:broader :Requirement ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
.

:LocalRoadsFacilitiesKnowledge
    a skos:Concept ;
    skos:prefLabel "Knowledge of local roads, facilities, and resources"@en ;
    skos:broader :CommunityEnvironmentKnowledge ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
.

:DiverseNeedsAwareness
    a skos:Concept ;
    skos:prefLabel "Understanding diverse needs within the community"@en ;
    skos:broader :CommunityEnvironmentKnowledge ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
.

:LocalSupportServicesAwareness
    a skos:Concept ;
    skos:prefLabel "Awareness of local support services"@en ;
    skos:broader :CommunityEnvironmentKnowledge ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
.

### Legal Category
:Legal
    a skos:Concept ;
    skos:prefLabel "Legal"@en ;
    skos:definition "Legal requirements and compliance checks for volunteering."@en ;
    skos:broader :Requirement ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
.

:IDCheck
    a skos:Concept ;
    skos:prefLabel "ID Check"@en ;
    skos:broader :Legal ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
.

:DBSCheck
    a skos:Concept ;
    skos:prefLabel "DBS Check"@en ;
    skos:broader :Legal ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
.

### Physical & Practical Readiness Category
:PhysicalPracticalReadiness
    a skos:Concept ;
    skos:prefLabel "Physical & Practical Readiness"@en ;
    skos:definition "Physical capability and practical preparation requirements for volunteering."@en ;
    skos:broader :Requirement ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
.

:PhysicalStamina
    a skos:Concept ;
