:Unemployment
    a skos:Concept ;
    skos:prefLabel "Unemployment"@en ;
    skos:altLabel "Job Loss"@en, "Redundancy"@en, "Unemployed People"@en, "Joblessness"@en, "Tackling Unemployment"@en, "Nonemployment"@en, "Unemployed"@en, "Jobless"@en, "Out of work"@en, "Unwaged"@en, "Without Work"@en ;
    skos:definition "Volunteering supporting unemployed people, job training, employment support, and livelihood development."@en ;
    skos:broader :Cause ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
.

:VictimsOfCrime
    a skos:Concept ;
    skos:prefLabel "Victims of Crime"@en ;
    skos:altLabel "Victim Support"@en, "Victim Counselling"@en, "Witness Support"@en, "Survivors"@en ;
    skos:definition "Volunteering supporting crime victims, victim advocacy, witness support, and survivor services."@en ;
    skos:broader :CrimeSafety ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
.

:WomensGroups
    a skos:Concept ;
    skos:prefLabel "Womens Groups"@en ;
    skos:altLabel "Womens Support Groups"@en, "Female Peer Suport"@en, "Female Groups"@en ;
    skos:definition "Volunteering in women's groups, female peer support, and women-focused community services."@en ;
    skos:broader :Cause ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
.

:YouthAndChildren
    a skos:Concept ;
    skos:prefLabel "Youth & children"@en ;
    skos:altLabel "Young People and Kids"@en, "Young folks & kids"@en, "Children"@en, "Babies"@en, "Toddlers"@en, "Minors"@en, "Kids"@en, "Infants"@en, "Young People"@en, "Teenagers"@en, "Young Adults"@en, "Youths"@en, "Younger Generation"@en ;
    skos:definition "Volunteering supporting youth development, children's welfare, and young people's services."@en ;
    skos:broader :Cause ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
.

# Volunteering vocabulary

## Namespaces
### Ontology Base URI
prefix :                <https://ns.volunteeringdata.io/>

### Core W3C ontologies (OWL 2 reserved vocabulary)
prefix rdf:             <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
prefix rdfs:            <http://www.w3.org/2000/01/rdf-schema#>
prefix owl:             <http://www.w3.org/2002/07/owl#>
prefix xsd:             <http://www.w3.org/2001/XMLSchema#>

### Other namespaces used
prefix dc:              <http://purl.org/dc/terms/>
prefix skos:            <http://www.w3.org/2004/02/skos/core#>
prefix time:            <http://www.w3.org/2006/time#>
prefix vcard:           <http://www.w3.org/2006/vcard/ns#>
prefix vann:            <http://purl.org/vocab/vann/>


## Taxonomy top concept
:Requirement
    a skos:Concept ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    skos:topConceptOf :Taxonomy ;
    skos:prefLabel "Requirement"@en ;
    skos:definition "Any requirement related to volunteering activities."@en ;
.


## Requirement Category Concepts
### Assets & Equipment Category
:AssetsEquipment
    a skos:Concept ;
    skos:prefLabel "Assets & Equipment"@en ;
    skos:definition "Physical items, equipment, vehicles, and assets needed for volunteering activities."@en ;
    skos:broader :Requirement ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
.

:PersonalEquipment
    a skos:Concept ;
    skos:prefLabel "Personal Equipment"@en ;
    skos:definition "Personal protective equipment and personal items for volunteering."@en ;
    skos:broader :AssetsEquipment ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
.

:SturgyFootwear
    a skos:Concept ;
    skos:prefLabel "Sturdy footwear (e.g., boots)"@en ;
    skos:broader :PersonalEquipment ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
.

:WaterproofsWarmLayers
    a skos:Concept ;
    skos:prefLabel "Waterproofs and warm layers"@en ;
    skos:broader :PersonalEquipment ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
.

:Gloves
    a skos:Concept ;
